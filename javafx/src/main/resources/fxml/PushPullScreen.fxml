<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gitanic.controllers.PushPullController" style="-fx-padding: 20;">
    <HBox spacing="10">
        <Button text="← Back to Diff" onAction="#onBackClicked"/>
        <Label text="Push / Pull" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    </HBox>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Pull from Origin" onAction="#onPullClicked" HBox.hgrow="ALWAYS" maxWidth="Double.MAX_VALUE"/>
        <Button text="Push to Origin" onAction="#onPushClicked" HBox.hgrow="ALWAYS" maxWidth="Double.MAX_VALUE"/>
    </HBox>
    
    <Label fx:id="statusLabel" textFill="BLUE"/>
    
    <TextArea fx:id="outputArea" VBox.vgrow="ALWAYS" editable="false" style="-fx-font-family: monospace;"/>
</VBox>
