# ==========================================
# GITANIC: Global Environment Configuration
# ==========================================

# --- SUPABASE ---
# Standard Database URL (Session pooler recommended: port 5432 or 6543)
DATABASE_URL="postgres://postgres.xxx:YOURpassword@aws-0-xx.pooler.supabase.com:6543/postgres"

# Supabase Project Management Keys
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# --- BACKEND (RAILWAY) ---
# Random string for JWT generation
JWT_SECRET="your_random_jwt_secret"
# Random string for hook security
INTERNAL_SECRET="your_internal_hook_secret"

# Git repository local storage mount config
REPOS_ROOT="/repos"
PORT=3000
SYNC_REPOS_ON_STARTUP="true"

# Server identification for callbacks
GIT_HOST="api.gitanic.com"
INTERNAL_BASE_URL="http://localhost:3000"

# --- FRONTEND (VERCEL) ---
RAILWAY_API_URL="https://api.gitanic.com"
ROOT_DOMAIN="gitanic.com"
EDGE_CONFIG=""