# ── Database (pg) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-before-production

# ── Git repos root (Local Windows Example) ──────────────────
REPOS_ROOT=C:/repos

# Default: true in development, false in production
SYNC_REPOS_ON_STARTUP=true

# ── Internal hook security ──────────────────────────────────
INTERNAL_SECRET=change-me-internal-secret
INTERNAL_BASE_URL=http://localhost:3000

# ── Git remote URL host ─────────────────────────────────────
GIT_HOST=localhost:3000

# ── Frontend Link ───────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# ── Static Site Server ──────────────────────────────────────
SERVE_PORT=4000

# ── Mailer (OTP) ────────────────────────────────────────────
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # Gmail App Password (Settings → Security → App Passwords)

OTP_STATIC=000000
