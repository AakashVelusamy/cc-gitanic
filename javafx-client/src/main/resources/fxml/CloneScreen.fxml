<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gitanic.controllers.CloneController" style="-fx-padding: 20;">
    <Button text="← Back" onAction="#onBackClicked"/>
    <Label text="Clone Repository" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    
    <Label text="Repository URL:"/>
    <TextField fx:id="urlField" promptText="http://..."/>
    
    <Label text="Clone into:"/>
    <HBox spacing="10">
        <TextField fx:id="pathField" promptText="/path/to/folder" HBox.hgrow="ALWAYS"/>
        <Button text="Browse..." onAction="#onBrowseClicked"/>
    </HBox>
    
    <Button text="Clone" onAction="#onCloneClicked" maxWidth="1.7976931348623157E308"/>
    <Label fx:id="statusLabel" wrapText="true"/>
</VBox>
